generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────
model User {
  id                String    @id @default(uuid())
  name              String
  email             String    @unique
  passwordHash      String
  role              Role      @default(BUYER)
  phone             String?
  location          String?
  bio               String?
  avatarUrl         String?
  coverUrl          String?

  // Auth
  verified          Boolean   @default(false)
  active            Boolean   @default(true)
  emailVerifiedAt   DateTime?
  lastLoginAt       DateTime?

  // Seller verification badge
  verifiedSeller    Boolean   @default(false)

  // Stats
  rating            Float     @default(0)
  ratingCount       Int       @default(0)
  cancelCount       Int       @default(0)

  // Revendedor system
  revendedorId      String?
  revendedor        User?     @relation("RevendedorSellers", fields: [revendedorId], references: [id])
  sellers           User[]    @relation("RevendedorSellers")
  inviteId          String?
  invite            RevendedorInvite? @relation(fields: [inviteId], references: [id])

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  bazar             Bazar?
  orders            Order[]   @relation("BuyerOrders")
  sellerOrders      Order[]   @relation("SellerOrders")
  reviewsGiven      Review[]  @relation("ReviewsByUser")
  reviewsReceived   Review[]  @relation("ReviewsForSeller")
  notifications     Notification[]
  chatsAsA          Chat[]    @relation("ChatUserA")
  chatsAsB          Chat[]    @relation("ChatUserB")
  messagesSent      Message[]
  favorites         Favorite[]
  cartItems         CartItem[]
  tokens            RefreshToken[]
  verificationCodes VerificationCode[]
  reports           Report[]  @relation("ReportsByUser")
  reportsAgainst    Report[]  @relation("ReportsAgainstUser")
  invitesCreated    RevendedorInvite[] @relation("InviteCreator")
  loginAttempts     LoginAttempt[]

  @@index([email])
  @@index([role])
  @@index([revendedorId])
}

enum Role {
  ADMIN
  REVENDEDOR
  SELLER
  BUYER
}

// ─────────────────────────────────────────────
// AUTH TOKENS
// ─────────────────────────────────────────────
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)
  userAgent String?
  ipAddress String?

  @@index([token])
  @@index([userId])
}

model VerificationCode {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  purpose   CodePurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, purpose])
}

enum CodePurpose {
  EMAIL_VERIFY
  PASSWORD_RESET
  TWO_FACTOR
}

model LoginAttempt {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email     String
  success   Boolean
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
}

// ─────────────────────────────────────────────
// BAZARS
// ─────────────────────────────────────────────
model Bazar {
  id          String   @id @default(uuid())
  sellerId    String   @unique
  seller      User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  name        String
  slug        String   @unique
  description String   @db.Text
  category    String
  phone       String?
  location    String?
  bannerUrl   String?
  logoUrl     String?
  active      Boolean  @default(true)

  // Financial
  feeRate       Float   @default(2.0)
  pendingFees   Float   @default(0)
  paidFees      Float   @default(0)
  totalSales    Float   @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]
  orders      Order[]
  transactions Transaction[]

  @@index([slug])
  @@index([category])
  @@index([active])
}

// ─────────────────────────────────────────────
// PRODUCTS
// ─────────────────────────────────────────────
model Product {
  id             String   @id @default(uuid())
  bazarId        String
  bazar          Bazar    @relation(fields: [bazarId], references: [id], onDelete: Cascade)
  sellerId       String
  name           String
  description    String   @db.Text
  price          Float
  category       String
  stock          Int      @default(0)
  condition      String   @default("Novo")
  size           String?
  color          String?
  location       String?
  deliveryMethod String   @default("Combinado")
  active         Boolean  @default(true)
  featured       Boolean  @default(false)

  // Stats
  rating         Float    @default(0)
  ratingCount    Int      @default(0)
  sales          Int      @default(0)
  views          Int      @default(0)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  images         ProductImage[]
  orderItems     OrderItem[]
  reviews        Review[]
  favorites      Favorite[]
  cartItems      CartItem[]
  reports        Report[]

  @@index([bazarId])
  @@index([category])
  @@index([active])
  @@index([sellerId])
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  publicId  String? // Cloudinary public_id
  order     Int     @default(0)

  @@index([productId])
}

// ─────────────────────────────────────────────
// CART
// ─────────────────────────────────────────────
model CartItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  qty       Int      @default(1)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// FAVORITES
// ─────────────────────────────────────────────
model Favorite {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────
model Order {
  id          String      @id @default(uuid())
  buyerId     String
  buyer       User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  sellerId    String
  seller      User        @relation("SellerOrders", fields: [sellerId], references: [id])
  bazarId     String
  bazar       Bazar       @relation(fields: [bazarId], references: [id])
  status      OrderStatus @default(PENDENTE)

  // Buyer info
  buyerName   String
  buyerPhone  String
  address     String
  payment     String
  size        String?
  color       String?
  notes       String?     @db.Text

  // Financial
  subtotal    Float
  feeRate     Float       @default(2.0)
  feeAmount   Float       @default(0)
  total       Float

  rated       Boolean     @default(false)
  deliveredAt DateTime?
  cancelledAt DateTime?
  cancelReason String?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  items       OrderItem[]
  review      Review?
  transaction Transaction?

  @@index([buyerId])
  @@index([sellerId])
  @@index([bazarId])
  @@index([status])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String
  price     Float
  qty       Int
  imageUrl  String?

  @@index([orderId])
}

enum OrderStatus {
  PENDENTE
  ACEITE
  EM_PREPARACAO
  EM_ENTREGA
  ENTREGUE
  CANCELADA
}

// ─────────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────────
model Review {
  id         String  @id @default(uuid())
  orderId    String  @unique
  order      Order   @relation(fields: [orderId], references: [id])
  productId  String
  product    Product @relation(fields: [productId], references: [id])
  sellerId   String
  seller     User    @relation("ReviewsForSeller", fields: [sellerId], references: [id])
  buyerId    String
  buyer      User    @relation("ReviewsByUser", fields: [buyerId], references: [id])
  rating     Int
  comment    String? @db.Text
  createdAt  DateTime @default(now())

  @@index([sellerId])
  @@index([productId])
}

// ─────────────────────────────────────────────
// TRANSACTIONS
// ─────────────────────────────────────────────
model Transaction {
  id        String          @id @default(uuid())
  bazarId   String
  bazar     Bazar           @relation(fields: [bazarId], references: [id])
  orderId   String?         @unique
  order     Order?          @relation(fields: [orderId], references: [id])
  sellerId  String
  type      TransactionType
  amount    Float
  fee       Float           @default(0)
  description String
  createdAt DateTime        @default(now())

  @@index([bazarId])
  @@index([sellerId])
}

enum TransactionType {
  VENDA
  PAGAMENTO
  AJUSTE
  REEMBOLSO
}

// ─────────────────────────────────────────────
// CHAT & MESSAGES
// ─────────────────────────────────────────────
model Chat {
  id        String    @id @default(uuid())
  userAId   String
  userA     User      @relation("ChatUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userBId   String
  userB     User      @relation("ChatUserB", fields: [userBId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

model Message {
  id        String   @id @default(uuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  text      String   @db.Text
  read      Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([chatId])
  @@index([senderId])
  @@index([read])
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────
model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType @default(INFO)
  title     String
  message   String           @db.Text
  link      String?
  read      Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, read])
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  ORDER
  CHAT
  REVIEW
  SYSTEM
}

// ─────────────────────────────────────────────
// REPORTS / DENUNCIAS
// ─────────────────────────────────────────────
model Report {
  id           String       @id @default(uuid())
  reporterId   String
  reporter     User         @relation("ReportsByUser", fields: [reporterId], references: [id])
  targetUserId String?
  targetUser   User?        @relation("ReportsAgainstUser", fields: [targetUserId], references: [id])
  targetProductId String?
  targetProduct   Product?  @relation(fields: [targetProductId], references: [id])
  type         ReportType
  reason       String
  description  String       @db.Text
  status       ReportStatus @default(PENDENTE)
  resolvedAt   DateTime?
  resolvedBy   String?
  resolution   String?      @db.Text
  createdAt    DateTime     @default(now())

  @@index([status])
  @@index([reporterId])
}

enum ReportType {
  PRODUCT
  USER
  BAZAR
}

enum ReportStatus {
  PENDENTE
  EM_ANALISE
  RESOLVIDA
  ARQUIVADA
}

// ─────────────────────────────────────────────
// REVENDEDOR INVITES
// ─────────────────────────────────────────────
model RevendedorInvite {
  id          String   @id @default(uuid())
  token       String   @unique
  note        String?
  createdById String
  createdBy   User     @relation("InviteCreator", fields: [createdById], references: [id])
  used        Boolean  @default(false)
  usedAt      DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  usedByUsers User[]

  @@index([token])
}

// ─────────────────────────────────────────────
// AUDIT LOGS
// ─────────────────────────────────────────────
model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entity     String?
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
